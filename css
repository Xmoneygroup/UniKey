body {
    margin: 0;
    padding: 0;
    font-family: 'Playfair Display', serif; /* Font luksoz */
    background-color: #1a1a1a; /* Ngjyrë e errët për sfondin */
}

.sfondi-luksoz {
    background-image: url('imazhi-sfondit-luksoz.jpg'); /* Zëvendësoni me imazhin tuaj */
    background-size: cover;
    background-position: center;
    width: 100%;
    height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
    overflow: hidden; /* Fsheh skajet e animacionit */
}

.titulli-animuar {
    font-size: 5rem;
    color: #f1c40f; /* Ngjyrë ari */
    text-transform: uppercase;
    letter-spacing: 5px;
    animation: fadeInSlideIn 3s ease-in-out forwards; /* Emri i animacionit */
    text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.5); /* Shkëlqim i lehtë */
}

/* Animacioni Fade In dhe Slide In */
@keyframes fadeInSlideIn {
    0% {
        opacity: 0;
        transform: translateY(50px);
    }
    100% {
        opacity: 1;
        transform: translateY(0);
    }
}
